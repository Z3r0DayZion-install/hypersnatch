{
  "name": "system-utility-suite",
  "version": "1.0.0",
  "description": "System Utility and Diagnostic Tools",
  "main": "core/main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run obfuscate && npm run build-exe",
    "obfuscate": "node scripts/obfuscate.js",
    "build-exe": "electron-builder",
    "build-win": "electron-builder --win",
    "clean": "rimraf dist/ obfuscated/",
    "dev": "electron . --dev"
  },
  "keywords": [
    "utility",
    "diagnostic",
    "system",
    "tools",
    "maintenance"
  ],
  "author": "System Tools Inc",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^4.0.2",
    "rimraf": "^5.0.5"
  },
  "build": {
    "appId": "com.systemtools.utilitysuite",
    "productName": "System Utility Suite",
    "directories": {
      "output": "dist"
    },
    "files": [
      "obfuscated/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "obfuscated/core/main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/tool.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "System Tools"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/tool.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/tool.png",
      "category": "Utility"
    }
  }
}
