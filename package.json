{
  "name": "hypersnatch",
  "version": "1.2.0",
  "description": "HyperSnatch - Security-First Evidence Analyzer",
  "main": "src/main.js",
  "author": "HyperSnatch Security Team",
  "homepage": "https://hypersnatch.com",
  "license": "PROPRIETARY",
  "private": true,
  "keywords": [
    "evidence-analysis",
    "link-resurrection",
    "security-compliance",
    "forensic-platform",
    "electron",
    "desktop"
  ],
  "engines": {
    "node": "20.17.0"
  },
  "bin": {
    "hypersnatch-cli": "src/cli/hypersnatch-cli.js"
  },
  "dependencies": {
    "ajv": "6.12.6",
    "chrome-remote-interface": "^0.34.0"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "24.13.3"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "hs-core:prepare": "node scripts/prepare_hs_core.cjs",
    "sign:win": "node scripts/sign_windows.cjs",
    "strategy-pack:hash": "node scripts/hash_strategy_pack.cjs",
    "prebuild": "node scripts/prepare_hs_core.cjs",
    "predist": "node scripts/prepare_hs_core.cjs && node scripts/sign_windows.cjs --pre",
    "prepack": "node scripts/prepare_hs_core.cjs",
    "build": "electron-builder",
    "build:repro": "npm run hs-core:prepare && electron-builder --dir && npm run verify",
    "dist": "electron-builder --publish=never",
    "postdist": "node scripts/generate_manifest.cjs",
    "pack": "electron-builder --dir=dist",
    "verify": "node scripts/verify_release.js",
    "verify:golden": "node verify_golden.js",
    "verify:schema": "node scripts/verify_schema.cjs",
    "verify:release": "node ./scripts/verify_release.cjs",
    "ui:bridge": "node ./src/bridge/ui-bridge.js",
    "ui:open": "start ui/hypersnatch-ui.html",
    "build:wrapper": "node scripts/build_wrapper.js",
    "release:pack": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Compress-Archive -Path release\\* -DestinationPath dist\\HyperSnatch_release.zip -Force\"",
    "test": "node tests/smartdecode.test.js && node tests/dns_fallback.test.js",
    "test:ci": "node tests/smartdecode.test.js && node tests/dns_fallback.test.js",
    "test:online": "node scripts/verify_smartdecode.js --online",
    "proof": "node tests/proof_all_decoders.js",
    "postinstall": "npx --yes electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.hypersnatch.platform",
    "productName": "HyperSnatch",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/main.js",
      "src/preload.js",
      "src/security-crypto.js",
      "src/dompurify.js",
      "src/utils/logger.js",
      "src/utils/crash-logger.js",
      "src/core/",
      "core/",
      "modules/",
      "ui/hypersnatch-ui.html",
      "src/cli/hypersnatch-cli.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "timeStampServer": "http://timestamp.digicert.com",
      "publisherName": "HyperSnatch Security Team",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HyperSnatch",
      "uninstallDisplayName": "HyperSnatch",
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "hypersnatch-security",
      "repo": "hypersnatch"
    }
  }
}